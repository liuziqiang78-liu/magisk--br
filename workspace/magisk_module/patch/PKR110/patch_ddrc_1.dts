			};
			
			ddrc_strategy {
				oplus,temp_type = <0x00>;
				oplus,ratio_range = <0x14 0x1e 0x32 0x46 0x5a>;
				oplus,temp_range = <0xffffffce 0x64 0x15e>;
				
				strategy_ratio_range_min {
