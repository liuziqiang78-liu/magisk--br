/dts-v1/;
/plugin/;

/ {
	fragment@0 {
		target = <&oplus_mms_gauge>;
		__overlay__ {
			deep_spec,support;
			deep_spec,uv_thr = <0xaf0>;
			deep_spec,count_thr = <0>;
			deep_spec,vbat_soc = <0>;
			deep_spec,count_step = <0x00 0x00 0x00>;
			deep_spec,term_coeff = <0 0 0>;
			deep_spec,ddrc_strategy_name = "ddrc_curve";
			deep_spec,volt_step = <0x14>;
			
			deep_spec,ddbc_curve {
				oplus,temp_type = <0x00>;
				oplus,temp_range = <0xffffff9c 0x32 0xc8>;
				deep_spec,ddbc_temp_cold = <0x1f4 0xcb2 0x05 0x2710 0xc80 0x02>;
