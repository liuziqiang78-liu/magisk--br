					strategy_temp_normal = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_warm = <0x00 0xaf0 0xaf0 0x00>;
				};
				
				strategy_ratio_range_low {
					strategy_temp_cold = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_cool = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_normal = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_warm = <0x00 0xaf0 0xaf0 0x00>;
				};
				
				strategy_ratio_range_mid_low {
					strategy_temp_cold = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_cool = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_normal = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_warm = <0x00 0xaf0 0xaf0 0x00>;
				};
				
				strategy_ratio_range_mid {
					strategy_temp_cold = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_cool = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_normal = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_warm = <0x00 0xaf0 0xaf0 0x00>;
				};
				
				strategy_ratio_range_mid_high {
					strategy_temp_cold = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_cool = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_normal = <0x00 0xaf0 0xaf0 0x00>;
					strategy_temp_warm = <0x00 0xaf0 0xaf0 0x00>;
				};
				
				strategy_ratio_range_high {
					strategy_temp_cold = <0x00 0xaf0 0xaf0 0x00>;
